{
	"name": "@helmor/sidecar",
	"description": "Helmor's agent-orchestration sidecar process (Claude Agent SDK + Codex SDK).",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "bun run scripts/stage-vendor.ts && bun run scripts/build.ts",
		"dev:prepare": "bun run stage-vendor",
		"stage-vendor": "bun run scripts/stage-vendor.ts",
		"dev": "bun run src/index.ts",
		"test": "bun test",
		"typecheck": "bunx tsc --noEmit"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "0.3.154",
		"@anthropic-ai/claude-code": "2.1.154",
		"@cursor/sdk": "^1.0.12",
		"@earendil-works/pi-agent-core": "^0.75.4",
		"@earendil-works/pi-ai": "^0.75.4",
		"@openai/codex": "0.134.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.2"
	},
	"trustedDependencies": [
		"@anthropic-ai/claude-code"
	]
}
